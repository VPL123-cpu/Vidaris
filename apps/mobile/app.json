{
  "expo": {
    "name": "Vidaris",
    "slug": "vidaris",
    "version": "1.0.0",
    "scheme": "vidaris",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1020"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vidaris.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1020"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.vidaris.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"]
  }
}
